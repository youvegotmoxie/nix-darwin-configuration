// Project tasks configuration. See https://zed.dev/docs/tasks for documentation.
[
  {
    "label": "Build Docker Container (arm64)",
    "command": "cd $ZED_WORKTREE_ROOT && docker buildx build --platform 'linux/arm64' -t zed-task-run-image:latest -f $ZED_FILE $ZED_RELATIVE_DIR/ --no-cache --progress=plain",
    "allow_concurrent_runs": false,
    "shell": "system",
    "show_command": true,
    "show_summary": true,
    "tags": ["docker"],
    "reveal_target": "center",
  },
  {
    "label": "Build Docker Container (x86_64)",
    "command": "cd $ZED_WORKTREE_ROOT && docker buildx build --platform 'linux/amd64' -t zed-task-run-image:latest -f $ZED_FILE $ZED_RELATIVE_DIR/ --no-cache --progress=plain",
    "allow_concurrent_runs": false,
    "shell": "system",
    "show_command": true,
    "show_summary": true,
    "tags": ["docker"],
    "reveal_target": "center",
  },
  {
    "label": "Update Nix Darwin",
    "command": "nix flake update && nix flake archive && nh darwin switch .",
    "allow_concurrent_runs": false,
    "shell": "system",
    "show_command": true,
    "show_summary": true,
    "tags": ["nix"],
    "reveal_target": "center",
  },
  {
    "label": "Update Nix Darwin (dry-run)",
    "command": "nix flake update && nix flake archive && nh darwin switch -n .",
    "allow_concurrent_runs": false,
    "shell": "system",
    "show_command": false,
    "show_summary": true,
    "tags": ["nix"],
    "reveal_target": "center",
  },
  {
    "label": "Terraform Validate",
    "command": "cd $ZED_RELATIVE_DIR && terraform init -backend=false && terraform validate",
    "allow_concurrent_runs": false,
    "shell": "system",
    "show_command": true,
    "show_summary": true,
    "tags": ["terraform"],
    "reveal_target": "center",
  },
]
