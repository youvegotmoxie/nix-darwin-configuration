// Project tasks configuration. See https://zed.dev/docs/tasks for documentation.
[
  {
    "label": "Update Nix Darwin",
    "command": "nix flake update && nix flake archive",
    "allow_concurrent_runs": false,
    "shell": "system",
    "show_command": true,
    "show_summary": true,
    "tags": ["nix"],
    "reveal_target": "center",
  },
  {
    "label": "Nix Darwin Switch",
    "command": "nh darwin switch .",
    "allow_concurrent_runs": false,
    "shell": "system",
    "show_command": true,
    "show_summary": true,
    "tags": ["nix"],
    "reveal_target": "center",
  },
  {
    "label": "Nix Darwin Switch (dry-run)",
    "command": "nh darwin switch -n .",
    "allow_concurrent_runs": false,
    "shell": "system",
    "show_command": false,
    "show_summary": true,
    "tags": ["nix"],
    "reveal_target": "center",
  },
]
